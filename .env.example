# Clave de Gemini para analizar los videos.
# Obtén una gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=

# (Opcional) Modelo de Gemini. Por defecto: gemini-3.1-pro-preview
# (el más inteligente, prioriza calidad sobre velocidad).
# Alternativas más rápidas y baratas: gemini-3-flash-preview, gemini-2.5-pro,
# gemini-2.5-flash.
# GEMINI_MODEL=gemini-3.1-pro-preview
