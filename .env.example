# ==================================================
# OpenClaw + Telegram Bot - Variables de Entorno
# ==================================================
# Copia este archivo a .env.local y rellena los valores

# Token del bot de Telegram (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=tu_token_aqui

# Puerto del gateway de OpenClaw (por defecto: 18789)
OPENCLAW_GATEWAY_PORT=18789

# URL del gateway de OpenClaw para el dashboard Next.js
NEXT_PUBLIC_OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# Clave API de Anthropic (para el modelo de IA)
ANTHROPIC_API_KEY=tu_api_key_aqui
