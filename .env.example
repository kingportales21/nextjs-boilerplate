# Proveedor de IA a usar. "gemini" (por defecto) o "claude".
AI_PROVIDER=gemini

# --- Gemini (por defecto) ---
# Obtén una clave en https://aistudio.google.com/apikey
GEMINI_API_KEY=
# (Opcional) Modelo de Gemini. Por defecto: gemini-2.5-flash.
# Alternativas: gemini-2.5-pro (mejor calidad, más lento y caro).
# GEMINI_MODEL=gemini-2.5-flash

# --- Claude (fallback) ---
# Sólo necesario si AI_PROVIDER=claude. Obtén una en https://console.anthropic.com/
ANTHROPIC_API_KEY=
# (Opcional) Modelo de Claude. Por defecto: claude-sonnet-4-6.
# Alternativas: claude-opus-4-6 (más capaz, más caro).
# ANTHROPIC_MODEL=claude-sonnet-4-6
