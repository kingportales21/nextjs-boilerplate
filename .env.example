# Clave de la API de Anthropic para llamar a Claude desde /api/analyze.
# Obtén una en https://console.anthropic.com/
ANTHROPIC_API_KEY=

# (Opcional) Modelo de Claude a usar. Por defecto: claude-opus-4-6.
# Otras opciones: claude-sonnet-4-6 (más rápido y barato), claude-haiku-4-5-20251001.
# ANTHROPIC_MODEL=claude-opus-4-6
