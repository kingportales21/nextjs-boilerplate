# ============================================================
# OpenClaw Docker - Configuracion
# ============================================================
# Copia este archivo:  copy .env.openclaw.example .env.openclaw
# Luego rellena tus valores reales.
# ============================================================

# ----------------------------------------------------------
# 1. MODELO DE IA  (Gemini)
# ----------------------------------------------------------
# API key de Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=tu-api-key-de-gemini-aqui

# Modelo principal - formato: provider/model-id
OPENCLAW_PRIMARY_MODEL=google/gemini-3.1-pro

# ----------------------------------------------------------
# 2. TELEGRAM
# ----------------------------------------------------------
# Token del bot (obtenido de @BotFather en Telegram)
TELEGRAM_BOT_TOKEN=tu-token-de-botfather-aqui

# Politica de mensajes directos: pairing | allowlist | open | disabled
TELEGRAM_DM_POLICY=allowlist

# Tu user ID de Telegram (puedes obtenerlo con @userinfobot)
TELEGRAM_ALLOW_FROM=tu-user-id-aqui

# ----------------------------------------------------------
# 3. GATEWAY
# ----------------------------------------------------------
# Token de acceso al panel web (inventa uno seguro o dejalo vacio para auto-generar)
OPENCLAW_GATEWAY_TOKEN=

# Puerto del dashboard (default: 18789)
OPENCLAW_PORT=18789

# ----------------------------------------------------------
# 4. PAQUETES EXTRA (opcional)
# ----------------------------------------------------------
# Paquetes de sistema adicionales para el contenedor (separados por espacio)
# Ejemplo: OPENCLAW_DOCKER_APT_PACKAGES="ffmpeg build-essential"
OPENCLAW_DOCKER_APT_PACKAGES=
