# OpenClaw Docker Configuration
# Copy this file to .env.openclaw and fill in the values.

# Gateway token (generated during onboarding)
OPENCLAW_GATEWAY_TOKEN=

# Port for the OpenClaw dashboard (default: 18789)
OPENCLAW_PORT=18789

# Extra system packages to install in the container (space-separated)
# Example: OPENCLAW_DOCKER_APT_PACKAGES="ffmpeg build-essential"
OPENCLAW_DOCKER_APT_PACKAGES=

# Extra host directory mounts (comma-separated, format: host:container:mode)
# Example: OPENCLAW_EXTRA_MOUNTS=/home/user/projects:/home/node/projects:rw
OPENCLAW_EXTRA_MOUNTS=
